*.py[cod]
*$py.class
*.so

# Jupyter Notebook cache
.ipynb_checkpoints/

# Hugging Face and Gradio cache (if models are downloaded locally)
.huggingface/
.gradio/

# OS generated files
.DS_Store
Thumbs.db
