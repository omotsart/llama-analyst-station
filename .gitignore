# Secrets and API keys (CRITICAL)
.env
.env.local
.env.*
*.pem

# Virtual environments (Heavy, do not commit)
venv/
env/
.venv/
Scripts/

# Local output and results (Do not push generated reports)
outputs/
result_*.txt
analysis_*.pdf
analysis_*.docx

# Python cache and compiled files
